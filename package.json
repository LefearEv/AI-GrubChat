{
  "name": "ai-grubchat",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:migrate": "npm run db:migrate --workspace=apps/web",
    "db:studio": "npm run db:studio --workspace=apps/web"
  },
  "devDependencies": {
    "turbo": "^2.0.9"
  }
}
