# ============================================
# AI GrubChat — Environment Variables
# Salin file ini ke .env dan isi nilainya
# ============================================

# Database
DATABASE_URL="postgresql://postgres:123@localhost:5432/ai_grubchat"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="ganti-dengan-string-random-minimal-32-karakter"

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI APIs
GOOGLE_GENERATIVE_AI_API_KEY=""   # https://aistudio.google.com/
OPENAI_API_KEY=""                  # https://platform.openai.com/

# Socket Server
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
